PORT=3002
HF_TOKEN=your-huggingface-token-here
GROQ_API_KEY=your-groq-api-key-here

# Image Generation (Gradio Space for text-to-image)
IMAGE_SPACE=mrfakename/Z-Image-Turbo

# ControlNet v1.1 (Gradio Space for sketch-to-image)
CONTROLNET_SPACE=hysts/ControlNet-v1-1

# PaddleOCR-VL (AIStudio) - For OCR/Handwriting Recognition
PADDLEOCR_SERVER_URL=https://your-aistudio-server.aistudio-app.com
PADDLEOCR_ACCESS_TOKEN=your_aistudio_access_token

# ElevenLabs (Text-to-Speech)
# ELEVENLABS_API_KEY=your-elevenlabs-key-here

# CORS (comma-separated origins, default "*" allows all)
# ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000
