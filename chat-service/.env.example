# ─── Required (at least one) ──────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key-here
OPENROUTER_API_KEY=your-openrouter-api-key-here

# ─── Optional: Model overrides ───────────────────────────────────────────────
# CHAT_MODEL_PRIMARY=llama-3.3-70b-versatile
# CHAT_MODEL_FALLBACK=arcee-ai/trinity-large-preview:free
# CHAT_MODEL_VISION=meta-llama/llama-4-scout-17b-16e-instruct
# CHAT_MODEL_VISION_FALLBACK=openai/gpt-4o-mini

# ─── Optional: Tuning ────────────────────────────────────────────────────────
# CHAT_PORT=3003
# MAX_HISTORY_MESSAGES=20
# SESSION_TTL_HOURS=24

# ─── Optional: CORS (comma-separated origins, default "*") ───────────────────
# ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000
